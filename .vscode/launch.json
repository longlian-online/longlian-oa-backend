{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        // 主程序
        {
            "type": "java",
            "name": "AppApplication",
            "request": "launch",
            "mainClass": "online.longlian.app.AppApplication",
            "envFile": "${workspaceFolder}/.env",
            "projectName": "app"
        },
        // 附加 otel agent
        {
            "type": "java",
            "name": "AppApplicationWithOtel",
            "request": "launch",
            "mainClass": "online.longlian.app.AppApplication",
            "projectName": "app",
            "envFile": "${workspaceFolder}/.env",
            "vmArgs": "-javaagent:opentelemetry-javaagent.jar"
        },
        // 代码生成
        {
            "type": "java",
            "name": "CodeGenerator",
            "request": "launch",
            "mainClass": "online.longlian.generator.CodeGenerator",
            "projectName": "generator"
        }
    ]
}